TRADING_MODE=demo
MT5_LOGIN=TU_LOGIN
MT5_PASSWORD=TU_PASSWORD
MT5_SERVER=FBS-Demo

# --- Solo Linux/Mac: terminal MT5 corriendo bajo Wine ------------------------
DISPLAY=:99
WINEPREFIX=/home/USER/.wine_mt5
MT5_EXE=/home/USER/.wine_mt5/drive_c/Program Files/MetaTrader 5/terminal64.exe

# --- Solo Linux/Mac: bridge mt5linux (servidor corre con python de Wine) ----
MT5_BRIDGE_HOST=localhost
MT5_BRIDGE_PORT=8001
