# Copiar a .env y completar antes de correr main.py con conexion real.

# --- Cuenta MT5 ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=

# --- Bridge mt5linux (solo si corres el terminal bajo Wine en Linux) ---
MT5_BRIDGE_HOST=localhost
MT5_BRIDGE_PORT=18812

# --- Bridge EA opcional (solo si USE_EA_BRIDGE=True) ---
USE_EA_BRIDGE=False
MT5_COMMON_FILES_PATH=

# --- Seguridad: dejar en True hasta validar el comportamiento en demo ---
DRY_RUN=True

# --- AI optimizer opcional (OpenRouter) ---
AI_OPTIMIZER_ENABLED=False
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
